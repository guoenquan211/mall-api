APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
# 生产环境（宝塔 MySQL）用 mysql；本地开发可改为 sqlite
DRIVER = mysql
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = cocobrite
USERNAME = cocobrite
PASSWORD = your_mysql_password
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX =
DEBUG = false

[LANG]
default_lang = zh-cn
